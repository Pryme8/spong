# Copy this file to .env and fill in values for your environment.
# The server reads these at runtime; client variables (VITE_*) are baked in at build time.

# ── Server ─────────────────────────────────────────────────────────────────────

# HTTP + WebSocket listen port
PORT=3000

# Absolute path to the built client dist for single-process deploy (Docker / prod)
# Leave unset when running client and server separately.
PUBLIC_DIR=./client/dist

# Comma-separated allowed CORS origins. Leave unset or set to * to allow all (dev).
# Example: https://spong.game,https://www.spong.game
ALLOWED_ORIGINS=

# Capacity limits (tune for your server)
MAX_CONNECTIONS=100
MAX_ROOMS=20
MAX_PLAYERS_PER_ROOM=8

# Sentry DSN for server-side crash reporting
SENTRY_DSN=

# ── Client (baked in at build time) ────────────────────────────────────────────

# Override WebSocket URL if client and server are on different origins.
# Leave unset for same-origin deploys.
VITE_WS_URL=

# PostHog analytics
VITE_POSTHOG_KEY=

# Sentry browser DSN
VITE_SENTRY_DSN=
